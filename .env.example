# XRPL wasm devnet seeds — required (wallets used server-side)
XRPL_PROVIDER_SEED=sEd...
XRPL_BORROWER_SEED=sEd...
XRPL_LOANBROKER_SEED=sEd...

# Public addresses (exposed to client for role detection)
NEXT_PUBLIC_PROVIDER_ADDRESS=r...
NEXT_PUBLIC_BORROWER_ADDRESS=r...
NEXT_PUBLIC_LOANBROKER_ADDRESS=r...

# Xaman wallet API key (get one at https://apps.xumm.dev/)
NEXT_PUBLIC_XAMAN_API_KEY=your-xaman-api-key

# API auth — both values must match
API_SECRET_KEY=generate-a-strong-random-string
NEXT_PUBLIC_API_KEY=generate-a-strong-random-string

# Pinata IPFS (get JWT at https://pinata.cloud/)
PINATA_JWT=eyJ...
PINATA_SECRET_API=
PINATA_PUBLIC_API=
